# --- CONFIGURATION BASE DE DONNÉES ---
DATABASE_URL=postgresql://user:password@localhost:5432/haiti_data_db

# --- CONFIGURATION IA (LLM & EMBEDDINGS) ---
OPENAI_API_KEY=REDACTED

LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# --- CONFIGURATION VECTOR STORE ---
CHROMA_DB_PATH=./data/chroma_db
COLLECTION_NAME=hadi_docs

# --- CONFIGURATION EXTRACTION ---
# Certains endpoints peuvent nécessiter des clés (ex: WB, FMI API keys si volume élevé)
WB_API_KEY=
IMF_API_KEY=

# --- CONFIGURATION SERVEUR ---
BACKEND_URL=http://localhost:8000
FRONTEND_PORT=8501
DEBUG=True

